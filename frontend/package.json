{
  "name": "grok-proxy-desktop",
  "version": "2.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings=0",
    "build": "pnpm typecheck && vite build && node -e \"require('fs').writeFileSync('dist/gitkeep', 'Wails embedded assets')\"",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4"
  }
}
